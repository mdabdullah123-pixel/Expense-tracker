# AI-Powered Expense Tracker - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenAI Configuration (Optional - for Cloud AI)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration (Optional - for Cloud AI)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter Configuration (Optional - for Cloud AI)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama Configuration (Optional - for Local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Application Settings
APP_NAME=AI Expense Tracker
APP_VERSION=1.0.0
DEBUG=False