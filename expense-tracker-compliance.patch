index 0000000..a097b8e
--- /dev/null
+++ b/.gitlab-ci.yml
@@ -0,0 +1,83 @@
+stages:
+  - quality
+  - security
+  - test
+
+variables:
+  PIP_CACHE_DIR: "$CI_PROJECT_DIR/.cache/pip"
+
+default:
+  image: python:3.11-slim
+  before_script:
+    - python -m pip install --upgrade pip
+    - pip install -r requirements.txt
+
+cache:
+  paths:
+    - .cache/pip
+
+ruff:
+  stage: quality
+  script:
+    - ruff check .
+    - ruff format --check .
+
+mypy:
+  stage: quality
+  script:
+    - mypy .
+
+pylint:
+  stage: quality
+  script:
+    - pylint app.py database pages services utils
+
+flake8:
+  stage: quality
+  script:
+    - flake8 .
+
+vulture:
+  stage: quality
+  script:
+    - vulture .
+
+pyupgrade:
+  stage: quality
+  script:
+    - pyupgrade --py311-plus app.py database/*.py pages/*.py services/*.py utils/*.py tests/*.py
+
+semgrep:
+  stage: security
+  script:
+    - semgrep --config=auto --error .
+
+bandit:
+  stage: security
+  script:
+    - bandit -r .
+
+secret-scanning:
+  stage: security
+  image:
+    name: zricethezav/gitleaks:latest
+    entrypoint: [""]
+  before_script: []
+  script:
+    - gitleaks detect --source . --verbose
+
+dependency-audit:
+  stage: security
+  script:
+    - pip-audit
+
+pytest:
+  stage: test
+  script:
+    - pytest
+  coverage: '/TOTAL.*\s+(\d+%)$/'
+  artifacts:
+    reports:
+      coverage_report:
+        coverage_format: cobertura
+        path: coverage.xml
